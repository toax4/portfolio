{% extends 'base.html.twig' %}

{% block title %}Développeur Full Stack @ Entreprise A | Adrien Bockelandt{% endblock %}
{% block meta_description %}Développeur Full Stack chez Entreprise A — mission, responsabilités et stack technique.{% endblock %}
{% block og_title %}Développeur Full Stack @ Entreprise A | Adrien Bockelandt{% endblock %}
{% block og_description %}Mission, responsabilités et stack technique.{% endblock %}
{% block twitter_title %}Développeur Full Stack @ Entreprise A | Adrien Bockelandt{% endblock %}
{% block twitter_description %}Mission, responsabilités et stack technique.{% endblock %}

{% block body %}
    <section class="pt-32 pb-16 px-4 max-w-5xl mx-auto border-b-4 border-black">
        <a href="{{ path('index') }}#experience"
            class="inline-flex items-center gap-2 font-mono font-bold text-sm mb-8 hover:bg-neo-yellow border-2 border-black px-3 py-1 shadow-hard-sm cursor-hover">
            <i class="ri-arrow-left-line"></i> RETOUR AU PORTFOLIO
        </a>

        <div
            class="inline-block bg-neo-purple text-white border-2 border-black px-4 py-1 mb-6 font-mono font-bold text-sm shadow-hard rotate-[-1deg]">
            (exemple — à remplacer par les infos du vrai poste)
        </div>

        <h1 class="text-4xl md:text-7xl font-black uppercase tracking-tighter mb-4 leading-[0.95] reveal">
            Développeur<br>Full Stack
        </h1>
        <p class="font-mono text-xl md:text-2xl font-bold mb-8 text-neo-purple reveal">@ Entreprise A</p>

        <div class="flex gap-2 font-mono text-xs font-bold flex-wrap mb-10 reveal">
            <span class="bg-neo-black text-white px-3 py-1">2024 - PRÉSENT</span>
            <span class="bg-neo-black text-white px-3 py-1">CDI (exemple)</span>
            <span class="bg-neo-black text-white px-3 py-1">Toulon / Remote (exemple)</span>
        </div>

        <div class="flex flex-col md:flex-row gap-4 reveal">
            <a href="{{ path('index') }}#contact"
                class="bg-black text-white border-2 border-black px-8 py-4 font-bold shadow-hard hover:bg-neo-green hover:text-black hover:translate-x-1 hover:translate-y-1 hover:shadow-none transition-all cursor-hover flex items-center justify-center gap-2">
                <i class="ri-mail-line text-xl"></i> ME CONTACTER
            </a>
            <a href="#"
                class="bg-neo-white text-black border-2 border-black px-8 py-4 font-bold shadow-hard hover:bg-neo-pink hover:translate-x-1 hover:translate-y-1 hover:shadow-none transition-all cursor-hover flex items-center justify-center gap-2">
                <i class="ri-building-line text-xl"></i> SITE DE L'ENTREPRISE
            </a>
        </div>
    </section>

    <section class="py-16 px-4 max-w-5xl mx-auto">
        <h2 class="text-4xl md:text-5xl font-black uppercase mb-6 reveal">Le poste</h2>
        <p class="font-mono text-lg leading-relaxed text-gray-700 reveal">
            (exemple) Contexte de la mission : dans quelle équipe, sur quel produit, avec quels enjeux. Par exemple
            : au sein d'une équipe produit de 4 développeurs, en charge de la conception et du développement
            d'applications web PHP/Symfony pour les clients de l'entreprise.
        </p>
    </section>

    <section class="py-16 bg-neo-black text-white border-y-4 border-black relative overflow-hidden">
        <div class="absolute inset-0 opacity-20"
            style="background-image: linear-gradient(#333 1px, transparent 1px), linear-gradient(90deg, #333 1px, transparent 1px); background-size: 40px 40px;">
        </div>
        <div class="max-w-5xl mx-auto px-4 relative z-10">
            <h2 class="text-4xl md:text-5xl font-black uppercase mb-10 reveal">Missions clés</h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div class="reveal border-2 border-white/20 p-6 hover:border-neo-green transition-colors">
                    <i class="ri-code-s-slash-line text-3xl text-neo-green mb-3 block"></i>
                    <h3 class="font-black uppercase mb-2">Développement</h3>
                    <p class="font-mono text-sm text-gray-400">(exemple) Développement et maintenance
                        d'applications web avec PHP / Symfony.</p>
                </div>
                <div class="reveal border-2 border-white/20 p-6 hover:border-neo-green transition-colors">
                    <i class="ri-plug-line text-3xl text-neo-green mb-3 block"></i>
                    <h3 class="font-black uppercase mb-2">API & Intégrations</h3>
                    <p class="font-mono text-sm text-gray-400">(exemple) Conception d'API REST consommées par des
                        clients web et mobile.</p>
                </div>
                <div class="reveal border-2 border-white/20 p-6 hover:border-neo-green transition-colors">
                    <i class="ri-team-line text-3xl text-neo-green mb-3 block"></i>
                    <h3 class="font-black uppercase mb-2">Collaboration</h3>
                    <p class="font-mono text-sm text-gray-400">(exemple) Collaboration avec l'équipe produit pour
                        prioriser les fonctionnalités.</p>
                </div>
            </div>
        </div>
    </section>

    <section class="py-16 px-4 max-w-5xl mx-auto">
        <h2 class="text-4xl md:text-5xl font-black uppercase mb-6 reveal">Stack technique</h2>
        <div class="flex gap-3 font-mono font-bold flex-wrap reveal">
            <span class="bg-white border-2 border-black px-4 py-2 shadow-hard-sm">PHP 8</span>
            <span class="bg-white border-2 border-black px-4 py-2 shadow-hard-sm">Symfony</span>
            <span class="bg-white border-2 border-black px-4 py-2 shadow-hard-sm">MySQL</span>
            <span class="bg-white border-2 border-black px-4 py-2 shadow-hard-sm">Twig</span>
            <span class="bg-white border-2 border-black px-4 py-2 shadow-hard-sm">Git</span>
        </div>
    </section>

    <section class="py-16 bg-neo-yellow border-y-4 border-black px-4">
        <div class="max-w-6xl mx-auto">
            <h2 class="text-4xl md:text-5xl font-black uppercase mb-10 text-white drop-shadow-[3px_3px_0_rgba(0,0,0,1)]"
                style="-webkit-text-stroke: 2px black;">Réalisations clés</h2>
            <p class="font-mono text-black/70 mb-8 -mt-6">(exemple — remplace par tes vrais chiffres/résultats)</p>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div class="reveal bg-white border-4 border-black p-6 shadow-hard text-center">
                    <div class="text-5xl font-black mb-2">3</div>
                    <p class="font-mono text-sm uppercase text-gray-600">Modules livrés</p>
                </div>
                <div class="reveal bg-white border-4 border-black p-6 shadow-hard text-center">
                    <div class="text-5xl font-black mb-2">-30%</div>
                    <p class="font-mono text-sm uppercase text-gray-600">Temps de traitement</p>
                </div>
                <div class="reveal bg-white border-4 border-black p-6 shadow-hard text-center">
                    <div class="text-5xl font-black mb-2">4</div>
                    <p class="font-mono text-sm uppercase text-gray-600">Développeurs dans l'équipe</p>
                </div>
            </div>
        </div>
    </section>

    <section class="py-24 px-4 max-w-3xl mx-auto text-center">
        <h2 class="text-4xl font-black uppercase mb-6 reveal">Une expérience à discuter ?</h2>
        <div class="flex flex-col md:flex-row justify-center gap-4 reveal">
            <a href="{{ path('index') }}#contact"
                class="bg-black text-white border-2 border-black px-8 py-4 font-bold shadow-hard hover:bg-neo-green hover:text-black hover:translate-x-1 hover:translate-y-1 hover:shadow-none transition-all cursor-hover">
                ME CONTACTER
            </a>
            <a href="{{ path('index') }}#experience"
                class="bg-white text-black border-2 border-black px-8 py-4 font-bold shadow-hard hover:bg-neo-pink hover:translate-x-1 hover:translate-y-1 hover:shadow-none transition-all cursor-hover">
                VOIR LES AUTRES EXPÉRIENCES
            </a>
        </div>
    </section>
{% endblock %}
