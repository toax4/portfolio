<article
    class="reveal group bg-white border-4 border-black p-4 shadow-hard{% if category is defined and category %} grid-item {{ category }} w-full md:w-[47%] mb-8{% else %} break-inside-avoid mb-12{% endif %}{% if tech is defined and tech %}{% for t in tech %} tech-{{ t }}{% endfor %}{% endif %}">
	{% include 'partials/_project_preview.html.twig' with { src: image|default(null), alt: title } %}
	<div class="flex justify-between items-start">
		<div>
			{% if category_label is defined and category_label %}
				<span class="inline-block bg-neo-black text-white font-mono text-[10px] font-bold uppercase px-2 py-1 mb-2">{{ category_label }}</span>
			{% endif %}
			<h3 class="text-4xl font-black uppercase mb-2 {{ hover_class|default('group-hover:text-neo-purple') }} transition-colors glitch-hover">
				{{ title }}</h3>
			<p class="font-mono text-sm mb-4 max-w-xs">{{ description }}</p>
			<div class="flex gap-2 font-mono text-xs font-bold flex-wrap">
				{% for tag in tags %}
					<span class="bg-neo-black text-white px-2 py-1">{{ tag }}</span>
				{% endfor %}
			</div>
		</div>
		<a href="{{ href|default('#') }}" class="w-12 h-12 border-2 border-black bg-neo-green flex items-center justify-center hover:bg-black hover:text-white transition-all cursor-hover shadow-hard-sm shrink-0">
			<i class="ri-arrow-right-up-line text-2xl"></i>
		</a>
	</div>
</article>
