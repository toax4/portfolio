<article class="reveal group bg-white border-4 border-black p-4 shadow-hard grid-item w-full mb-8 break-inside-avoid mb-12 {% if types is defined and types %}{% for type in types %} {{ type|slugify }}{% endfor %}{% endif %} {% if technologies is defined and technologies %}{% for t in technologies %} tech-{{ t|slugify }}{% endfor %}{% endif %} {% if more_classes is defined and more_classes %}{{ more_classes }}{% endif %}">
	{% include 'partials/_project_preview.html.twig' with { cover: cover|default(null), alt: title } %}
	<div class="flex justify-between items-start">
		<div>
			<div class="flex gap-2 font-mono text-xs font-bold flex-wrap mb-2">
				{% for type in types %}
					<span class="bg-neo-black text-white px-2 py-1">{{ type }}</span>
				{% endfor %}
			</div>
			{% if category_label is defined and category_label %}
				<span class="inline-block bg-neo-black text-white font-mono text-[10px] font-bold uppercase px-2 py-1 mb-2">{{ category_label }}</span>
			{% endif %}
			<h3 class="text-4xl font-black uppercase mb-2 {{ hover_class|default('group-hover:text-neo-purple') }} transition-colors glitch-hover">
				{{ title }}</h3>
			{% if description is defined and description %}
				<p class="font-mono text-sm mb-4">{{ description }}</p>
			{% endif %}
			<div class="flex gap-2 font-mono text-xs font-bold flex-wrap mb-2">
				{% for tech in technologies %}
					<span class="bg-neo-black text-white px-2 py-1">{{ tech }}</span>
				{% endfor %}
			</div>
		</div>
		<a href="{{ href|default('#') }}" class="w-12 h-12 border-2 border-black bg-neo-green flex items-center justify-center hover:bg-black hover:text-white transition-all cursor-hover shadow-hard-sm shrink-0">
			<i class="ri-arrow-right-up-line text-2xl"></i>
		</a>
	</div>
</article>
