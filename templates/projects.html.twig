{% endblock %}
{% block og_description %}Tous les projets réalisés par Adrien Bockelandt, développeur Full Stack.
{% endblock %}
{% block twitter_title %}Tous mes projets | Adrien Bockelandt
{% endblock %}
{% block twitter_description %}Tous les projets réalisés par Adrien Bockelandt, développeur Full Stack.
{% endblock %}

{% block stylesheets %}
	<style>
		.grid-sizer,
		.gutter-sizer {
			margin: 0;
			padding: 0;
			height: 0;
			visibility: hidden;
		}

		/* Isotope only fades filtered-out items (opacity: 0), it doesn't remove them
           from the tab/click flow — this keeps invisible cards from being clickable
           or focusable while they're filtered out. */
		.grid-item[aria-hidden="true"] {
			pointer-events: none;
		}
	</style>
{% endblock %}

{% block body %}
	<section class="pt-32 pb-16 px-4 max-w-7xl mx-auto border-b-4 border-black">
		<a href="{{ path('index') }}" class="inline-flex items-center gap-2 font-mono font-bold text-sm mb-8 hover:bg-neo-yellow border-2 border-black px-3 py-1 shadow-hard-sm cursor-hover">
			<i class="ri-arrow-left-line"></i>
			RETOUR À L'ACCUEIL
		</a>

		<h1 class="text-6xl md:text-9xl font-black uppercase tracking-tighter mb-4 leading-[0.85] reveal">
			Tous mes<br>Projets
		</h1>
		<p class="font-mono text-black/60 mb-10 reveal">(exemple — cette liste s'agrandira au fur et à mesure de tes
																																	            projets)</p>

		<div class="space-y-3 reveal">
			<div class="flex gap-3 flex-wrap font-mono font-bold text-sm" data-filter-group="category">
				<button data-filter="*" class="filter-btn active bg-neo-yellow border-2 border-black px-4 py-2 shadow-hard-sm cursor-hover">TOUS</button>
				{% for slug, type in filter_types %}
					<button data-filter=".{{slug}}" class="filter-btn bg-white border-2 border-black px-4 py-2 shadow-hard-sm cursor-hover">{{type}}</button>
				{% endfor %}
			</div>

			<div class="flex gap-3 flex-wrap font-mono font-bold text-sm" data-filter-group="tech">
				<button data-filter="*" class="filter-btn active bg-neo-yellow border-2 border-black px-3 py-1.5 shadow-hard-sm cursor-hover text-xs">TOUTES TECHNOS</button>
				{% for slug, techno in filter_technologies %}
					<button data-filter=".tech-{{slug}}" class="filter-btn bg-white border-2 border-black px-4 py-2 shadow-hard-sm cursor-hover">{{techno}}</button>
				{% endfor %}
				{# <button data-filter=".tech-php" class="filter-btn bg-white border-2 border-black px-3 py-1.5 shadow-hard-sm cursor-hover text-xs">PHP</button>
																				<button data-filter=".tech-symfony" class="filter-btn bg-white border-2 border-black px-3 py-1.5 shadow-hard-sm cursor-hover text-xs">SYMFONY</button>
																				<button data-filter=".tech-laravel" class="filter-btn bg-white border-2 border-black px-3 py-1.5 shadow-hard-sm cursor-hover text-xs">LARAVEL</button>
																				<button data-filter=".tech-node" class="filter-btn bg-white border-2 border-black px-3 py-1.5 shadow-hard-sm cursor-hover text-xs">NODE.JS</button>
																				<button data-filter=".tech-flutter" class="filter-btn bg-white border-2 border-black px-3 py-1.5 shadow-hard-sm cursor-hover text-xs">FLUTTER</button>
																				<button data-filter=".tech-bootstrap" class="filter-btn bg-white border-2 border-black px-3 py-1.5 shadow-hard-sm cursor-hover text-xs">BOOTSTRAP</button>
																				<button data-filter=".tech-mysql" class="filter-btn bg-white border-2 border-black px-3 py-1.5 shadow-hard-sm cursor-hover text-xs">MYSQL</button>
																				<button data-filter=".tech-mongodb" class="filter-btn bg-white border-2 border-black px-3 py-1.5 shadow-hard-sm cursor-hover text-xs">MONGODB</button> #}
			</div>
		</div>
	</section>

	<section class="py-24 bg-neo-yellow border-b-4 border-black px-4 overflow-hidden">
		<div class="max-w-7xl mx-auto">
			<div class="relative columns-1 md:columns-2 gap-12" id="projects-grid">
				<div class="grid-sizer w-full md:w-[47%]"></div>
				<div class="gutter-sizer w-full md:w-[6%]"></div>

				{% set hover_classes = ['group-hover:text-neo-purple', 'group-hover:text-neo-blue', 'group-hover:text-neo-pink'] %}
