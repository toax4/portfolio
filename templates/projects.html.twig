{% endblock %}

{% block extra_scripts %}
	<script src="/js/isotope.min.js" defer></script>
	<script defer>
		document.addEventListener('DOMContentLoaded', function () {
var grid = document.getElementById('projects-grid');
if (! grid || typeof Isotope === 'undefined') {
return;
}

var iso = new Isotope(grid, {
itemSelector: '.grid-item',
layoutMode: 'masonry',
percentPosition: true,
masonry: {
columnWidth: '.grid-sizer',
gutter: '.gutter-sizer'
}
});

// Two filter rows (type + techno) must both match at once. Isotope's
// function-based filter calls filterFn(element) — NOT filterFn.call(element) —
// so the element is read from the argument, not from `this`.
var activeFilters = {
category: '*',
tech: '*'
};

function itemMatchesFilters(element) {
var matchesCategory = activeFilters.category === '*' || element.matches(activeFilters.category);
var matchesTech = activeFilters.tech === '*' || element.matches(activeFilters.tech);
return matchesCategory && matchesTech;
}

// Isotope only fades filtered-out items, it doesn't detach them from the
// page — mark them aria-hidden and untabbable so they're not clickable
// or reachable by keyboard/screen readers while invisible.
function syncFilteredState() {
grid.querySelectorAll('.grid-item').forEach(function (item) {
var link = item.querySelector('a');
if (itemMatchesFilters(item)) {
item.removeAttribute('aria-hidden');
if (link) 
link.removeAttribute('tabindex');



} else {
item.setAttribute('aria-hidden', 'true');
if (link) 
link.setAttribute('tabindex', '-1');



}
});
}

document.querySelectorAll('[data-filter-group]').forEach(function (row) {
var groupName = row.getAttribute('data-filter-group');
var buttons = row.querySelectorAll('.filter-btn');
buttons.forEach(function (button) {
button.addEventListener('click', function () {
buttons.forEach(function (b) {
b.classList.remove('bg-neo-yellow');
b.classList.add('bg-white');
});
button.classList.remove('bg-white');
button.classList.add('bg-neo-yellow');
activeFilters[groupName] = button.getAttribute('data-filter');
iso.arrange({filter: itemMatchesFilters});
syncFilteredState();
});
});
});
});
	</script>
{% endblock %}
